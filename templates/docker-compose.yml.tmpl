name: __ENVNAME__

services:
  # ---- Claude Code が動く本体 ----
  claude:
    build: .
    command: sleep infinity  # tmux を生かし続ける(exec で入る)。dotfiles setup は task up で実行する。
    environment:
      - TERM=xterm-256color
      - COLORTERM=truecolor
      - SSH_AUTH_SOCK=/ssh-agent         # git の ssh はホストの agent に委譲
      - GH_TOKEN=${GH_TOKEN:-}           # 任意: PATが取れる場合のみ(空ならgh auth loginを使う)
      - CLAUDE_DOTFILES_DIR=/dotfiles/claude
      - CLAUDE_ENV_NAME=__ACCT_PROJECT__ # claude --name 用(push通知/ターミナルタイトルに案件名)
      # riku_dx_web の pnpm dev は dind 上に postgres を起動する。
      # claude コンテナ内の localhost ではなく、隣の dind コンテナへ接続する。
      - POSTGRES_HOST=dind
      - POSTGRES_PORT=5432
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB=rikudxdb
      - DATABASE_URL=postgresql://postgres:postgres@dind:5432/rikudxdb
      - BACKEND_URL=http://localhost:8000
      - UV_LINK_MODE=copy
      - PYTHONDONTWRITEBYTECODE=1
    volumes:
      - __PROJECT__:/workspace                     # 隣の案件リポジトリ(ソース共有)

      # ---- 汎用: 言語/ツール別の依存・ビルドキャッシュ ----
      # macOS ホストと Linux コンテナで node_modules / .venv / native cache を共有しない。
      # 別プロジェクトでもよく使う root レイアウト向けの隔離先。
      - root-node-modules:/workspace/node_modules
      - root-venv:/workspace/.venv
      - pnpm-store:/workspace/.pnpm-store
      - root-turbo:/workspace/.turbo
      - root-ruff-cache:/workspace/.ruff_cache
      - go-mod-cache:/home/user/go/pkg/mod
      - go-build-cache:/home/user/.cache/go-build

      # ---- riku_dx_web 固有: monorepo 配下の生成物・キャッシュ ----
      - frontend-node-modules:/workspace/apps/frontend/node_modules
      - frontend-next:/workspace/apps/frontend/.next
      - backend-venv:/workspace/apps/backend/.venv
      - backend-turbo:/workspace/apps/backend/.turbo
      - backend-pytest-cache:/workspace/apps/backend/.pytest_cache
      - backend-ruff-cache:/workspace/apps/backend/.ruff_cache
      - frontend-ruff-cache:/workspace/apps/frontend/.ruff_cache
      # ---- protected external: 認証・初回状態。docker compose down -v でも削除されない ----
      - __ACCT__-claude-enterprise:/home/user/.claude    # Claude OAuth / credentials(account内で共有)
      - __ACCT__-claude-state:/home/user/.claude-state   # ~/.claude.json(machineID / firstStartTime 等)
      - __ACCT__-gh-config:/home/user/.config/gh         # gh auth login の保存先(account内で共有)
      - __CLAUDE_DOTFILES__:/dotfiles/claude:ro           # dotfiles の Claude Code 設定
      - ${HOST_SSH_AUTH_SOCK:-/run/host-services/ssh-auth.sock}:/ssh-agent
      # github-gg 等の SSH エイリアスはイメージ側の ~/.ssh/config で github.com へ
      # 解決済み(Dockerfile 参照)。host の config をマウントする必要は無い。
    working_dir: /workspace
    depends_on: [dind]

  # ---- 案件を隔離して動かす Docker-in-Docker ----
  dind:
    image: docker:27-dind
    privileged: true
    environment:
      - DOCKER_TLS_CERTDIR=              # 内部ネットワーク限定の簡易構成(TLSなし)
    volumes:
      - __PROJECT__:/workspace           # claude と同じパス(bind mount 整合のため)
      - dind-storage:/var/lib/docker     # イメージキャッシュ(この案件専用)

volumes:
  # この案件専用(name で namespace 化されるので他案件と衝突しない)。
  # ※ 2つのデーモンで /var/lib/docker を共有すると破損するため絶対に external 共有しない。
  dind-storage:

  # ---- 汎用: 言語/ツール別の依存・ビルドキャッシュ ----
  # プロジェクト bind mount より優先して、ホスト側の生成物を隠す。
  root-node-modules:
  root-venv:
  pnpm-store:
  root-turbo:
  root-ruff-cache:
  go-mod-cache:
  go-build-cache:

  # ---- riku_dx_web 固有: monorepo 配下の生成物・キャッシュ ----
  frontend-node-modules:
  frontend-next:
  backend-venv:
  backend-turbo:
  backend-pytest-cache:
  backend-ruff-cache:
  frontend-ruff-cache:

  # ---- protected external: 認証・初回状態 ----
  # Compose 管理外なので docker compose down -v でも削除されない。
  # 初回に手動作成:  docker volume create __ACCT__-claude-enterprise
  __ACCT__-claude-enterprise:
    external: true

  # Claude Code の ~/.claude.json(machineID / firstStartTime 等)。
  # 初回に手動作成:  docker volume create __ACCT__-claude-state
  __ACCT__-claude-state:
    external: true

  # gh auth login の保存先。同じ account のプロジェクトで共有(会社アカウント1つ)。
  # 初回に手動作成:  docker volume create __ACCT__-gh-config
  __ACCT__-gh-config:
    external: true
