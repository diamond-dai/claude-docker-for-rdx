name: __ENVNAME__

services:
  # ---- Claude Code が動く本体 ----
  claude:
    build: .
    command: bash -lc "setup-claude-dotfiles && sleep infinity"  # tmux を生かし続ける(exec で入る)
    environment:
      - SSH_AUTH_SOCK=/ssh-agent         # git の ssh はホストの agent に委譲
      - GH_TOKEN=${GH_TOKEN:-}           # 任意: PATが取れる場合のみ(空ならgh auth loginを使う)
      - CLAUDE_DOTFILES_DIR=/dotfiles/claude
      # riku_dx_web の pnpm dev は dind 上に postgres を起動する。
      # claude コンテナ内の localhost ではなく、隣の dind コンテナへ接続する。
      - POSTGRES_HOST=dind
      - POSTGRES_PORT=5432
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB=rikudxdb
      - DATABASE_URL=postgresql://postgres:postgres@dind:5432/rikudxdb
      - BACKEND_URL=http://localhost:8000
      - UV_LINK_MODE=copy
      - PYTHONDONTWRITEBYTECODE=1
    volumes:
      - __PROJECT__:/workspace                     # 隣の案件リポジトリ(ソース共有)
      # macOS ホストと Linux コンテナで依存ディレクトリを共有しない。
      # 共有すると .venv や native package が片方の環境向けに壊れる。
      - root-node-modules:/workspace/node_modules
      - frontend-node-modules:/workspace/apps/frontend/node_modules
      - frontend-next:/workspace/apps/frontend/.next
      - backend-venv:/workspace/apps/backend/.venv
      - pnpm-store:/workspace/.pnpm-store
      # 環境差のあるキャッシュもコンテナ専用にする。
      - root-turbo:/workspace/.turbo
      - backend-turbo:/workspace/apps/backend/.turbo
      - root-ruff-cache:/workspace/.ruff_cache
      - backend-pytest-cache:/workspace/apps/backend/.pytest_cache
      - backend-ruff-cache:/workspace/apps/backend/.ruff_cache
      - frontend-ruff-cache:/workspace/apps/frontend/.ruff_cache
      - __ACCT__-claude-enterprise:/home/node/.claude    # エンタープライズ認証(account内で共有)
      - __ACCT__-gh-config:/home/node/.config/gh         # gh auth login の保存先(account内で共有)
      - __CLAUDE_DOTFILES__:/dotfiles/claude:ro           # dotfiles の Claude Code 設定
      - ${HOST_SSH_AUTH_SOCK:-/run/host-services/ssh-auth.sock}:/ssh-agent
      # github-gg エイリアスをコンテナ内でも使う場合のみ(パスは環境に合わせる):
      # - ~/.ssh/config:/home/node/.ssh/config:ro
      # - ~/ssh_keys/gg/gg-github/gg-git_id_ed25519.pub:/home/node/ssh_keys/gg/gg-github/gg-git_id_ed25519.pub:ro
    working_dir: /workspace
    depends_on: [dind]

  # ---- 案件を隔離して動かす Docker-in-Docker ----
  dind:
    image: docker:27-dind
    privileged: true
    environment:
      - DOCKER_TLS_CERTDIR=              # 内部ネットワーク限定の簡易構成(TLSなし)
    volumes:
      - __PROJECT__:/workspace           # claude と同じパス(bind mount 整合のため)
      - dind-storage:/var/lib/docker     # イメージキャッシュ(この案件専用)

volumes:
  # この案件専用(name で namespace 化されるので他案件と衝突しない)。
  # ※ 2つのデーモンで /var/lib/docker を共有すると破損するため絶対に external 共有しない。
  dind-storage:

  # claude コンテナ専用の依存キャッシュ。プロジェクト bind mount より優先して
  # ホスト側 node_modules / .venv を隠す。
  root-node-modules:
  frontend-node-modules:
  frontend-next:
  backend-venv:
  pnpm-store:
  root-turbo:
  backend-turbo:
  root-ruff-cache:
  backend-pytest-cache:
  backend-ruff-cache:
  frontend-ruff-cache:

  # 認証は同じ account のプロジェクトで共有 + 誤削除防止のため external。
  # 初回に手動作成:  docker volume create __ACCT__-claude-enterprise
  __ACCT__-claude-enterprise:
    external: true

  # gh auth login の保存先。同じ account のプロジェクトで共有(会社アカウント1つ)。
  # 初回に手動作成:  docker volume create __ACCT__-gh-config
  __ACCT__-gh-config:
    external: true
